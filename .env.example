# ── kql-lab environment overrides ─────────────────────────────────────────────
# Copy this file to .env and adjust values.
# .env is gitignored — safe to store local settings here.
# setup.sh loads .env automatically if present.

# How many days of Windows events to retain in Kustainer.
# ADX automatically drops extents older than this (no manual cleanup needed).
# Lower = less disk. Minimum practical value: 1.
DATA_RETENTION_DAYS=7

# Disk space thresholds for the setup.sh pre-flight check (GB).
# Warn if free space drops below DATA_WARN_GB.
# Abort  if free space drops below DATA_MIN_FREE_GB.
DATA_WARN_GB=2
DATA_MIN_FREE_GB=1
